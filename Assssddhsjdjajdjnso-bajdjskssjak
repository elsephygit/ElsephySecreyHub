def process_announce(message):
    if message.from_user.id != OWNER_ID:
        return
    
    announce_text = message.text
    c.execute("SELECT user_id FROM users")
    users = c.fetchall()
    
    success = 0
    for user in users:
        try:
            bot.send_message(user[0], f"рҹ“ў <b>DUYURU</b>\nв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\n{announce_text}")
            success += 1
            time.sleep(0.05)
        except:
            pass
    
    bot.send_message(OWNER_ID, f"вң… Duyuru {success} kullaniciya gonderildi.")

def process_add_credit(message):
    if message.from_user.id != OWNER_ID:
        return
    
    try:
        parts = message.text.split()
        user_id = int(parts[0])
        amount = int(parts[1])
        add_credit(user_id, amount)
        bot.send_message(OWNER_ID, f"вң… {user_id} ID'li kullaniciya {amount} kredi eklendi.")
        bot.send_message(user_id, f"рҹҺү Hesabiniza {amount} kredi eklendi! Yeni bakiye: {get_user_credit(user_id)}")
    except:
        bot.send_message(OWNER_ID, "вқҢ Hatali format! Ornek: 8682060694 50")

