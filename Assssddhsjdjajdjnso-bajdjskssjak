def detect_query_type(query):
    query = query.strip()
    
    if query.startswith('@'):
        return 'telegram', query
    if re.match(r'^[\+]?[0-9\s\-\(\)]{10,20}$', query):
        return 'phone', query
    if re.match(r'^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}$', query):
        return 'email', query
    if 'instagram.com/' in query:
        return 'instagram', query
    if 'tiktok.com/' in query:
        return 'tiktok', query
    if 'twitter.com/' in query or 'x.com/' in query:
        return 'twitter', query
    
    return 'telegram', query

def perform_osint_search(query, user_id):
    query_type, clean_query = detect_query_type(query)
    cache_key = hashlib.md5(f"{query_type}:{clean_query}".encode()).hexdigest()
    
    cached = get_from_cache(cache_key)
    if cached:
        return cached
    
    if query_type == 'phone':
        result = search_phone(clean_query, user_id)
        platform = 'phone'
        result_text = get_text(user_id, 'phone_result').format(info=result)
    elif query_type == 'email':
        result = search_email(clean_query, user_id)
        platform = 'email'
        result_text = get_text(user_id, 'email_result').format(info=result)
    elif query_type == 'telegram':
        result = search_telegram(clean_query, user_id)
        platform = 'telegram'
        result_text = get_text(user_id, 'telegram_result').format(info=result)
    elif query_type == 'instagram':
        result = search_instagram(clean_query, user_id)
        platform = 'instagram'
        result_text = get_text(user_id, 'instagram_result').format(info=result)
    elif query_type == 'tiktok':
        result = search_tiktok(clean_query, user_id)
        platform = 'tiktok'
        result_text = get_text(user_id, 'tiktok_result').format(info=result)
    elif query_type == 'twitter':
        result = search_twitter(clean_query, user_id)
        platform = 'twitter'
        result_text = get_text(user_id, 'twitter_result').format(info=result)
    else:
        result_text = get_text(user_id, 'not_found')
        platform = 'unknown'
    
    log_osint(user_id, query, query_type, platform, result)
    add_to_cache(cache_key, result_text, 3600)
    
    return result_text

