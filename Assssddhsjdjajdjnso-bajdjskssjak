def is_rate_limited(user_id):
    now = time.time()
    if user_id in user_last_command:
        if now - user_last_command[user_id] < RATE_LIMIT_SECONDS:
            return True
    user_last_command[user_id] = now
    return False

def get_user_lang(user_id):
    c.execute("SELECT language FROM users WHERE user_id=?", (user_id,))
    row = c.fetchone()
    return row[0] if row else 'tr'

def get_user_credit(user_id):
    c.execute("SELECT credit FROM users WHERE user_id=?", (user_id,))
    row = c.fetchone()
    return row[0] if row else START_CREDIT

def add_credit(user_id, amount):
    c.execute("UPDATE users SET credit = credit + ? WHERE user_id=?", (amount, user_id))
    conn.commit()

def deduct_credit(user_id, amount):
    current = get_user_credit(user_id)
    if current >= amount:
        c.execute("UPDATE users SET credit = credit - ? WHERE user_id=?", (amount, user_id))
        conn.commit()
        return True
    return False

def add_to_cache(key, value, duration=86400):
    c.execute("INSERT OR REPLACE INTO cache (key, value, expires) VALUES (?,?,?)",
              (key, json.dumps(value), int(time.time()) + duration))
    conn.commit()

def get_from_cache(key):
    c.execute("SELECT value, expires FROM cache WHERE key=?", (key,))
    row = c.fetchone()
    if row and row[1] > int(time.time()):
        return json.loads(row[0])
    return None

def log_osint(user_id, query, query_type, platform, result):
    c.execute("INSERT INTO osint_logs (user_id, query, query_type, platform, result, timestamp) VALUES (?,?,?,?,?,?)",
              (user_id, query[:200], query_type, platform, result[:1000], int(time.time())))
    conn.commit()
    c.execute("UPDATE users SET total_searches = total_searches + 1 WHERE user_id=?", (user_id,))
    conn.commit()

def is_channel_member(user_id):
    try:
        member = bot.get_chat_member(CHANNEL_USERNAME, user_id)
        return member.status in ['member', 'administrator', 'creator']
    except:
        return False

def get_random_ua():
    return random.choice(USER_AGENTS)

def make_request(url, timeout=15):
    headers = {'User-Agent': get_random_ua()}
    try:
        response = requests.get(url, headers=headers, timeout=timeout)
        return {'success': response.status_code == 200, 'content': response.text, 'status': response.status_code}
    except:
        return {'success': False, 'content': '', 'status': 0}

