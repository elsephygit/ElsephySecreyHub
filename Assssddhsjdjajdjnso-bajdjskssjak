        bot.answer_callback_query(call.id, f"Dil {lang.upper()} olarak ayarlandi!")
        bot.send_message(user_id, get_text(user_id, 'welcome'))
    
    elif data == "check_credit":
        credit = get_user_credit(user_id)
        bot.answer_callback_query(call.id, f"рҹ’Һ Kredin: {credit}", show_alert=True)
    
    elif data.startswith("repeat_"):
        query = data.replace("repeat_", "")
