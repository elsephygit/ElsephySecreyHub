    phone_clean = re.sub(r'[^0-9+]', '', phone)
    
    if phone_clean.startswith('0') and len(phone_clean) == 11:
        phone_clean = '+90' + phone_clean[1:]
    elif not phone_clean.startswith('+'):
        phone_clean = '+' + phone_clean
    
    try:
        parsed = phonenumbers.parse(phone_clean, None)
        country = geocoder.description_for_number(parsed, "tr")
        carrier_name = carrier.name_for_number(parsed, "tr")
        timezones = phone_tz.time_zones_for_number(parsed)
        is_valid = phonenumbers.is_valid_number(parsed)
        
        results.append(f"рҹ“һ Numara: {phone_clean}")
        results.append(f"рҹҢҚ Ulke: {country}")
        results.append(f"рҹ“Ў Operator: {carrier_name if carrier_name else 'Bilinmiyor'}")
        results.append(f"вң… Gecerli: {'Evet' if is_valid else 'Hayir'}")
        results.append(f"рҹ•җ Zaman Dilimi: {', '.join(timezones) if timezones else 'Bilinmiyor'}")
    except:
        results.append("вқҢ Gecersiz telefon numarasi formati")
    
    results.append(f"\nрҹ”— WhatsApp: https://wa.me/{phone_clean.replace('+', '')}")
    results.append(f"рҹ”— Telegram: https://t.me/{phone_clean.replace('+', '')}")
    
    return "\n".join(results)

def search_email(email, user_id):
